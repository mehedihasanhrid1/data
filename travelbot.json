            "responses": [
                "I can assist you with trip planning, destinations, packing, budgets, and safety tips. What would you like to explore?"
            ]
        }
    },
    "intents": [
        {
            "tag": "greeting",
            "keywords": [
                "hello",
                "hi",
                "hey",
                "start"
            ],
            "responses": [
                "Hello! I am your smart travel guide. How can I assist you today?"
            ]
        },
        {
            "tag": "plan",
            "keywords": [
                "plan",
                "trip",
                "tour",
                "travel"
            ],
