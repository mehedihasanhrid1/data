                    "Cox’s Bazar",
                    "Darjeeling",
                    "Pokhara"
                ],
                "Nature & Adventure": [
                    "Nepal",
                    "Bhutan",
                    "Kashmir"
                ],
                "City Life": [
                    "Dubai",
                    "Singapore",
                    "Bangkok"
                ]
            }
        },
        {
            "tag": "packing",
            "keywords": [
                "pack",
                "packing",
                "luggage",
                "bag"
